# RPC and chain settings
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# Deployer key (used to deploy + initialize + fund escrow)
DEPLOYER_PRIVATE_KEY=0xYOUR_KEY

# Optional API signer key (defaults to DEPLOYER_PRIVATE_KEY if omitted)
CLAIMER_PRIVATE_KEY=0xYOUR_API_SIGNER_KEY

# RP ID settings (choose one)
# RP_ID=your-app.vercel.app
# RP_ID_HASH=0x...
RP_ID_LOCALHOST=true

# Contract funding & claim amount (wei)
CLAIM_AMOUNT_WEI=10000000000000            # 0.001 ETH
FUND_AMOUNT_WEI=100000000000000            # 0.01 ETH

# Optional deployment flags
MAX_FEE_PER_GAS_GWEI=0.03
STYLUS_NO_VERIFY=true
